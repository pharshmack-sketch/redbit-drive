# RedBit Drive — Environment Variables
# Скопируйте в .env и заполните своими значениями

# ── Supabase Backend ─────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_KEY=your-supabase-anon-key

# ── Storage API URL ───────────────────────────────────────────────────────
# Адрес веб-приложения, через которое десктоп запрашивает presigned URL для S3.
# Десктоп НЕ знает о конфигурации S3 — всё хранится на бэкенде.
# При смене S3-провайдера меняются только env-переменные в Supabase Dashboard
# (S3_ENDPOINT, S3_ACCESS_KEY, S3_SECRET_KEY, S3_BUCKET_NAME).
# Код десктопного клиента при этом не изменяется.
#
# По умолчанию: https://app.pxbt.io
# Для разработки: http://localhost:3001 (mock-server)
VITE_STORAGE_API_URL=https://app.pxbt.io

# ── Mock Server (для тестирования без backend) ────────────────────────────
# Установите в "true" для использования мок-сервера
VITE_USE_MOCK=false
# URL мок-сервера (по умолчанию localhost:3001)
VITE_MOCK_URL=http://localhost:3001

# ── Версия приложения ─────────────────────────────────────────────────────
VITE_APP_VERSION=1.0.0
